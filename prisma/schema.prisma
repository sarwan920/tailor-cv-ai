generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  password  String      // Securely hashed using PBKDF2
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  profiles  CvProfile[]
  sessions  Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model CvProfile {
  id          String       @id @default(uuid())
  title       String
  content     String       // Markdown content of the CV
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tailoredCvs TailoredCv[]
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TailoredCv {
  id              String    @id @default(uuid())
  profileId       String
  profile         CvProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  jobTitle        String
  company         String
  jobDescription  String
  originalContent String
  tailoredContent String
  aiAnalysis      String    // JSON string containing extracted skills/keywords/metrics
  createdAt       DateTime  @default(now())
}
